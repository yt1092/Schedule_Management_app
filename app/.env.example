# Render PostgreSQL 接続情報
# Render ダッシュボードからコピーして設定してください

# ローカル開発環境用（SQLite）
# DATABASE_URL=sqlite:///./test.db

# Render PostgreSQL用
# DATABASE_URL=postgresql://[user]:[password]@[host]:5432/[database]

# 例:
# DATABASE_URL=postgresql://schedule_user:mypassword@host.render.com:5432/schedule_db
